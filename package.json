{
  "name": "apex-family-tree",
  "version": "2.2.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,green \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "build": "npm run build -w frontend && npm run build -w backend",
    "test": "npm run test -w frontend && npm run test -w backend",
    "lint": "eslint frontend/src backend/src",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,html}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.4.2"
  }
}
