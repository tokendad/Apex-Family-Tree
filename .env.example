# =============================================================================
# Apex Family Tree (AFT) — Environment Variables
# =============================================================================
# Copy this file to .env and update the values for your environment.
# All variables have sensible defaults for local development.

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------

# Application port (default: 3000)
PORT=3000

# Environment: development | production
NODE_ENV=development

# Secret key for application-level encryption (AES-256-GCM for SMTP passwords, etc.)
# REQUIRED in production — generate with: openssl rand -base64 32
APP_SECRET=change-me-to-a-random-secret

# Secret key for JWT token signing
# REQUIRED in production — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-another-random-secret

# JWT access token expiry (default: 15m)
JWT_ACCESS_EXPIRY=15m

# JWT refresh token expiry (default: 7d)
JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info

# Log format: json | text (default: text in dev, json in production)
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Docker / User Mapping
# -----------------------------------------------------------------------------

# User/Group ID for file permissions inside the container
# Match these to your host user to avoid permission issues
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# Email (SMTP) — Required for invite and password reset emails
# -----------------------------------------------------------------------------

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Google Cloud (Optional) — All default to "local" for self-hosted mode
# -----------------------------------------------------------------------------

# Storage backend: local | gcs (default: local)
STORAGE_BACKEND=local

# Google Cloud Storage bucket name (required if STORAGE_BACKEND=gcs)
# GCS_BUCKET=your-bucket-name

# Secrets backend: local | gcp-secret-manager (default: local)
SECRET_BACKEND=local

# GCP project ID (required for any GCP service)
# GCP_PROJECT_ID=your-project-id

# Logging backend: local | gcp-logging (default: local)
LOG_BACKEND=local

# Path to GCP service account key file (if not using Application Default Credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/app/data/gcp-key.json
